# Backend production example for Railway/Render.
# Copy these names into your host's environment variable settings.

APP_NAME=Municipal Infrastructure Monitor
DEBUG=false

# Replace with a long random value.
SECRET_KEY=change-me-use-a-long-random-secret
ALGORITHM=HS256

# Railway PostgreSQL variables can be mapped into these URLs.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL_SYNC=postgresql+psycopg://USER:PASSWORD@HOST:PORT/DATABASE

# Railway Redis variable can be mapped here.
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# Set after deploying the frontend.
FRONTEND_URL=https://your-vercel-app.vercel.app
CORS_ORIGINS=https://your-vercel-app.vercel.app

# Required for cross-site auth cookies when frontend and API are on different HTTPS domains.
COOKIE_SECURE=true
COOKIE_SAMESITE=none

# Keep lazy loading on small deployment instances.
EAGER_LOAD_ML_MODELS=false
EAGER_LOAD_LEAK_LSTM=false
YOLO_AUTO_TRAIN=false

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
